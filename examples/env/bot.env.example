TELEGRAM_BOT_TOKEN=<set-locally>
TELEGRAM_BOT_USERNAME=misis_digital_support_bot
SUPPORTDESK_API_URL=http://supportdesk-api:8080
METRICS_PORT=8090

# Optional: outbound proxy for environments where direct Telegram API access is not available.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,supportdesk-api,192.168.85.0/24

# Empty value means no Telegram user whitelist.
ALLOWED_TELEGRAM_USER_IDS=
